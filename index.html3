                        <div className="blog-card-body">
                          <span className="blog-tag" style={{background:`${o.tagColor}18`,color:o.tagColor,border:`1px solid ${o.tagColor}30`,fontSize:9}}>{o.tag}</span>
                          <div className="blog-card-title" style={{fontSize:13}}>{o.title}</div>
                        </div>
                      </div>
                    ))}
