<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="description" content="退去費用の不当請求から入居者を守る無料AIツール。診断・記録・交渉書類をすべて無料で。"/>
  <meta name="theme-color" content="#6366f1"/>
  <title>タチアイズ | 退去費用の不当請求をゼロに</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    :root{
      --bg:#f5f7ff;
      --bg2:#eef1fb;
      --surface:rgba(99,102,241,.06);
      --border:rgba(99,102,241,.14);
      --indigo:#6366f1;
      --indigo-l:#818cf8;
      --green:#16a34a;
      --amber:#d97706;
      --red:#dc2626;
      --text:#1e1b4b;
      --text2:#4b5563;
      --text3:#9ca3af;
      --nav-h:64px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      background:var(--bg);
      font-family:'Noto Sans JP','Hiragino Kaku Gothic ProN',sans-serif;
      -webkit-font-smoothing:antialiased;
      color:var(--text);
      overflow-x:hidden;
    }
    button,input,textarea,select{font-family:inherit;-webkit-tap-highlight-color:transparent}
    textarea{resize:none}

    /* NAV */
    .site-nav{
      position:fixed;top:0;left:0;width:100%;height:var(--nav-h);z-index:200;
      background:rgba(255,255,255,.95);backdrop-filter:blur(20px);
      border-bottom:1px solid rgba(99,102,241,.12);
      display:flex;align-items:center;padding:0 24px;gap:0;
    }
    .nav-logo{
      display:flex;align-items:center;gap:10px;
      font-size:17px;font-weight:900;color:var(--text);letter-spacing:-.02em;
      text-decoration:none;margin-right:auto;cursor:pointer;background:none;border:none;
    }
    .nav-logo-icon{
      width:32px;height:32px;border-radius:9px;
      background:linear-gradient(135deg,#6366f1,#818cf8);
      display:flex;align-items:center;justify-content:center;font-size:17px;
    }
    .nav-links{display:flex;gap:4px;margin-right:16px}
    @media(max-width:640px){.nav-links{display:none}}
    .nav-link{
      padding:8px 14px;border-radius:9px;border:none;
      background:transparent;color:var(--text2);font-size:13px;font-weight:500;cursor:pointer;
      transition:background .15s,color .15s;
    }
    .nav-link:hover{background:rgba(99,102,241,.08);color:var(--indigo)}
    .nav-cta{
      padding:9px 20px;border-radius:10px;border:none;
      background:linear-gradient(135deg,#6366f1,#818cf8);
      color:#fff;font-size:13px;font-weight:700;cursor:pointer;
      box-shadow:0 2px 16px rgba(99,102,241,.3);
      transition:opacity .15s,transform .1s;
    }
    .nav-cta:hover{opacity:.9;transform:translateY(-1px)}

    /* LAYOUT */
    .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
    @media(max-width:640px){.wrap{padding:0 16px}}
    section{padding:80px 0}
    @media(max-width:640px){section{padding:52px 0}}
    .sec-badge{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.1em;color:var(--indigo-l);margin-bottom:12px}
    .sec-h2{font-size:clamp(24px,3.5vw,38px);font-weight:900;letter-spacing:-.02em;color:var(--text);margin-bottom:14px;line-height:1.2}
    .sec-sub{font-size:14px;color:var(--text2);line-height:1.75;max-width:560px;margin-bottom:0}

    /* HERO */
    .hero{padding:calc(var(--nav-h) + 72px) 0 72px;position:relative}
    @media(max-width:640px){.hero{padding:calc(var(--nav-h) + 44px) 0 44px}}
    .hero-inner{
      max-width:1080px;margin:0 auto;padding:0 24px;
      display:grid;grid-template-columns:1fr 420px;gap:56px;align-items:center;
    }
    @media(max-width:900px){.hero-inner{grid-template-columns:1fr;gap:36px}}
    @media(max-width:640px){.hero-inner{padding:0 16px}}
    .hero-badge{
      display:inline-flex;align-items:center;gap:7px;
      background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.25);
      border-radius:999px;padding:5px 14px;
      font-size:12px;font-weight:700;color:#4f46e5;letter-spacing:.04em;margin-bottom:20px;
    }
    .hero-h1{font-size:clamp(30px,5vw,54px);font-weight:900;line-height:1.1;letter-spacing:-.03em;color:var(--text);margin-bottom:18px}
    .hero-h1 em{font-style:normal;background:linear-gradient(135deg,#818cf8,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero-sub{font-size:15px;color:var(--text2);line-height:1.75;margin-bottom:28px;max-width:460px}
    .hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:28px}
    .btn-primary{
      padding:14px 28px;border-radius:12px;border:none;
      background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;
      font-size:14px;font-weight:700;cursor:pointer;
      box-shadow:0 4px 24px rgba(99,102,241,.45);
      transition:transform .15s,opacity .15s;
    }
    .btn-primary:hover{transform:translateY(-2px)}
    .btn-ghost{
      padding:14px 22px;border-radius:12px;
      border:1px solid rgba(99,102,241,.2);background:#fff;
      color:var(--text2);font-size:14px;font-weight:600;cursor:pointer;
      transition:border-color .15s,color .15s;
    }
    .btn-ghost:hover{border-color:rgba(99,102,241,.5);background:rgba(99,102,241,.06);color:var(--indigo)}
    .trust-row{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
    .trust-item{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text3)}
    .trust-check{width:16px;height:16px;border-radius:5px;background:rgba(22,163,74,.12);border:1px solid rgba(22,163,74,.3);display:flex;align-items:center;justify-content:center;font-size:9px;color:#16a34a;font-weight:700}

    /* HERO CARD */
    .hero-card{
      background:#fff;border:1px solid rgba(99,102,241,.15);border-radius:20px;padding:24px;
      box-shadow:0 12px 48px rgba(99,102,241,.12),0 2px 8px rgba(0,0,0,.04);
    }
    .card-label{font-size:11px;color:var(--text3);font-weight:700;letter-spacing:.06em;margin-bottom:16px;display:flex;align-items:center;gap:8px}
    .diff-block{text-align:center;padding:18px 0;border-bottom:1px solid rgba(99,102,241,.1);margin-bottom:14px}
    .diff-amount{font-size:48px;font-weight:900;color:#16a34a;letter-spacing:-.03em;line-height:1}
    .diff-label{font-size:11px;color:var(--text3);margin-bottom:8px}
    .diff-sub{font-size:11px;color:var(--text2);margin-top:6px}
    .card-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(99,102,241,.07)}
    .card-row:last-child{border:none}
    .chip{display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;font-size:10px;font-weight:700}

    /* STATS BAR */
    .stats-bar{border-top:1px solid rgba(99,102,241,.12);border-bottom:1px solid rgba(99,102,241,.12);background:#fff}
    .stats-inner{max-width:1080px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:repeat(3,1fr)}
    @media(max-width:640px){.stats-inner{padding:0 16px}}
    .stat-cell{padding:28px 16px;text-align:center;border-right:1px solid rgba(99,102,241,.1)}
    .stat-cell:last-child{border:none}
    .stat-num{font-size:clamp(28px,4vw,42px);font-weight:900;letter-spacing:-.03em;line-height:1;background:linear-gradient(135deg,#6366f1,#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:6px}
    .stat-label{font-size:11px;color:var(--text3);letter-spacing:.04em}

    /* PAIN POINTS */
    .pain-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:36px}
    @media(max-width:640px){.pain-grid{grid-template-columns:1fr}}
    .pain-card{background:#fff;border:1px solid rgba(220,38,38,.15);border-radius:16px;padding:20px;box-shadow:0 2px 10px rgba(220,38,38,.05)}
    .pain-icon{font-size:22px;margin-bottom:10px}
    .pain-title{font-size:14px;font-weight:700;color:#dc2626;margin-bottom:6px}
    .pain-text{font-size:12px;color:var(--text2);line-height:1.65}
    .pain-sol{font-size:11px;color:#16a34a;background:rgba(22,163,74,.08);border:1px solid rgba(22,163,74,.2);border-radius:6px;padding:4px 10px;display:inline-block;margin-top:8px;font-weight:600}

    /* HOW IT WORKS */
    .how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:36px}
    @media(max-width:640px){.how-grid{grid-template-columns:1fr;gap:10px}}
    .how-card{background:#fff;border:1px solid rgba(99,102,241,.12);border-radius:18px;padding:24px;transition:border-color .2s,transform .2s,box-shadow .2s;box-shadow:0 2px 12px rgba(99,102,241,.06)}
    .how-card:hover{border-color:rgba(99,102,241,.35);transform:translateY(-3px);box-shadow:0 8px 32px rgba(99,102,241,.13)}
    .how-num{font-size:11px;font-weight:900;letter-spacing:.1em;color:var(--indigo-l);margin-bottom:12px}
    .how-icon{font-size:32px;margin-bottom:14px}
    .how-title{font-size:15px;font-weight:800;color:var(--text);margin-bottom:8px}
    .how-text{font-size:12px;color:var(--text2);line-height:1.7}

    /* DIAGNOSIS */
    .diag-wrap{max-width:600px;margin:36px auto 0}
    .diag-card{background:#fff;border:1px solid rgba(99,102,241,.14);border-radius:20px;padding:28px;box-shadow:0 4px 24px rgba(99,102,241,.08)}
    .step-bar{display:flex;gap:5px;margin-bottom:20px}
    .step-seg{flex:1;height:4px;border-radius:999px;transition:background .3s}
    .step-seg.done{background:var(--indigo)}
    .step-seg.cur{background:var(--indigo-l)}
    .step-seg.todo{background:rgba(99,102,241,.12)}
    .q-text{font-size:17px;font-weight:800;color:var(--text);line-height:1.6;margin-bottom:8px}
    .q-hint{font-size:12px;color:#4f46e5;background:rgba(99,102,241,.07);border-radius:10px;padding:10px 14px;margin-bottom:20px;line-height:1.6}
    .choice-btn{display:block;width:100%;text-align:left;background:#f8faff;border:1px solid rgba(99,102,241,.12);border-radius:14px;padding:16px 18px;margin-bottom:10px;cursor:pointer;transition:all .15s;color:var(--text)}
    .choice-btn:hover{background:rgba(99,102,241,.07);border-color:rgba(99,102,241,.35)}
    .sel-t{background:rgba(22,163,74,.07)!important;border-color:rgba(22,163,74,.35)!important}
    .sel-l{background:rgba(220,38,38,.07)!important;border-color:rgba(220,38,38,.35)!important}
    .sel-s{background:rgba(107,114,128,.1)!important;border-color:rgba(107,114,128,.3)!important}
    .choice-inner{display:flex;align-items:flex-start;gap:12px}
    .choice-emoji{font-size:20px;line-height:1.4;flex-shrink:0}
    .choice-label{font-size:13px;font-weight:600;line-height:1.65}
    .year-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:20px}
    @media(min-width:480px){.year-grid{grid-template-columns:repeat(5,1fr)}}
    .year-btn{padding:14px 8px;border-radius:12px;border:1px solid rgba(99,102,241,.14);background:#f8faff;font-size:14px;font-weight:700;cursor:pointer;color:var(--text2);transition:all .15s;text-align:center}
    .year-btn.on{background:rgba(99,102,241,.12);border-color:rgba(99,102,241,.45);color:var(--indigo)}
    .diag-btn{width:100%;padding:15px;border-radius:13px;border:none;background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 20px rgba(99,102,241,.35);transition:transform .1s}
    .diag-btn:hover{transform:translateY(-1px)}
    .score-box{text-align:center;padding:20px 0}
    .score-num{font-size:72px;font-weight:900;letter-spacing:-.04em;line-height:1}
    .score-unit{font-size:28px;font-weight:700}
    .score-label{font-size:16px;font-weight:800;margin-top:10px}
    .result-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(99,102,241,.08)}
    .result-row:last-child{border:none}
    .action-item{display:flex;gap:10px;align-items:flex-start;padding:10px 0;border-bottom:1px solid rgba(99,102,241,.06)}
    .action-item:last-child{border:none}
    .action-num{width:22px;height:22px;border-radius:7px;flex-shrink:0;background:rgba(99,102,241,.1);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--indigo)}

    /* CHECKLIST */
    .cl-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:36px}
    @media(max-width:640px){.cl-grid{grid-template-columns:1fr}}
    .cl-cat{background:#fff;border:1px solid rgba(99,102,241,.14);border-radius:18px;overflow:hidden;transition:border-color .2s;box-shadow:0 2px 12px rgba(99,102,241,.05)}
    .cl-cat-hd{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;cursor:pointer;transition:background .15s}
    .cl-cat-hd:hover{background:rgba(99,102,241,.04)}
    .cl-cat-left{display:flex;align-items:center;gap:12px}
    .cl-items{padding:0 18px 14px}
    .cl-item{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid rgba(99,102,241,.07);cursor:pointer}
    .cl-item:last-child{border:none}
    .cl-check{width:22px;height:22px;border-radius:7px;flex-shrink:0;border:1.5px solid rgba(99,102,241,.25);display:flex;align-items:center;justify-content:center;font-size:12px;transition:all .2s}
    .cl-check.on{background:#16a34a;border-color:#16a34a;color:#fff}
    .cl-prog-bar{height:3px;background:rgba(99,102,241,.1)}
    .cl-prog-fill{height:100%;background:linear-gradient(90deg,var(--indigo),var(--indigo-l));transition:width .4s ease}

    /* DOCUMENTS */
    .doc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:36px}
    @media(max-width:640px){.doc-grid{grid-template-columns:1fr}}
    .doc-card{background:#fff;border:1px solid rgba(99,102,241,.12);border-radius:18px;padding:20px;cursor:pointer;transition:border-color .2s,transform .2s,box-shadow .2s;display:flex;gap:14px;align-items:flex-start;box-shadow:0 2px 12px rgba(99,102,241,.05)}
    .doc-card:hover{border-color:rgba(99,102,241,.35);transform:translateY(-2px);box-shadow:0 8px 32px rgba(99,102,241,.12)}
    .doc-icon{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
    .doc-title{font-size:14px;font-weight:800;color:var(--text);margin-bottom:5px}
    .doc-desc{font-size:12px;color:var(--text2);line-height:1.6}

    /* GL TABLE */
    .gl-table{background:#fff;border:1px solid rgba(217,119,6,.2);border-radius:16px;padding:20px;margin-top:24px;max-width:560px;box-shadow:0 2px 12px rgba(217,119,6,.05)}
    .gl-title{font-size:12px;font-weight:700;color:#d97706;margin-bottom:14px;letter-spacing:.06em}
    .gl-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(99,102,241,.07)}
    .gl-row:last-child{border:none}

    /* OVERLAY */
    .overlay{position:fixed;inset:0;z-index:500;background:rgba(30,27,75,.7);backdrop-filter:blur(8px);display:flex;flex-direction:column;padding:24px}
    .overlay-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-top:8px}
    .overlay-close{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;padding:9px 16px;border-radius:10px;font-size:12px;cursor:pointer}
    .letter-body{flex:1;background:#fff;border:1px solid rgba(99,102,241,.12);border-radius:14px;padding:20px;overflow-y:auto;font-family:monospace;font-size:11px;color:#1e1b4b;line-height:1.9;white-space:pre-wrap;margin-bottom:16px}
    .copy-btn{width:100%;padding:15px;border-radius:13px;border:none;font-size:14px;font-weight:700;cursor:pointer}

    /* FOOTER */
    footer{border-top:1px solid rgba(99,102,241,.1);padding:36px 0;background:#fff}
    .footer-inner{max-width:1080px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
    @media(max-width:640px){.footer-inner{padding:0 16px}}
    .footer-note{font-size:11px;color:var(--text3);line-height:1.65;max-width:500px}

    /* GLOW */
    .glow{position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse at 15% 20%,rgba(99,102,241,.06) 0%,transparent 55%),radial-gradient(ellipse at 85% 80%,rgba(167,139,250,.04) 0%,transparent 55%)}

    @keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .fu{animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both}
    .fu2{animation:fadeUp .5s .12s cubic-bezier(.16,1,.3,1) both}

    /* ── BLOG ── */
    .blog-hero{padding:calc(var(--nav-h) + 64px) 0 48px;background:linear-gradient(160deg,#f0f3ff 0%,#e8ecff 100%);border-bottom:1px solid rgba(99,102,241,.12)}
    .blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px}
    @media(max-width:900px){.blog-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:640px){.blog-grid{grid-template-columns:1fr}}
    .blog-card{background:#fff;border:1px solid rgba(99,102,241,.1);border-radius:18px;overflow:hidden;cursor:pointer;transition:transform .2s,box-shadow .2s}
    .blog-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(99,102,241,.13)}
    .blog-card-img{height:160px;display:flex;align-items:center;justify-content:center;font-size:52px;border-bottom:1px solid rgba(99,102,241,.08)}
    .blog-card-body{padding:18px}
    .blog-tag{display:inline-block;padding:3px 10px;border-radius:999px;font-size:10px;font-weight:700;margin-bottom:10px}
    .blog-card-title{font-size:15px;font-weight:800;color:var(--text);line-height:1.5;margin-bottom:8px}
    .blog-card-excerpt{font-size:12px;color:var(--text2);line-height:1.7;margin-bottom:12px}
    .blog-card-meta{display:flex;align-items:center;gap:10px;font-size:11px;color:var(--text3)}

    /* Article page */
    .article-wrap{padding:calc(var(--nav-h) + 48px) 0 80px}
    @media(max-width:640px){.article-wrap{padding:calc(var(--nav-h) + 32px) 0 56px}}
    .article-inner{max-width:760px;margin:0 auto;padding:0 24px}
    @media(max-width:640px){.article-inner{padding:0 16px}}
    .article-tag{display:inline-block;padding:4px 12px;border-radius:999px;font-size:11px;font-weight:700;margin-bottom:16px}
    .article-h1{font-size:clamp(22px,3.5vw,36px);font-weight:900;line-height:1.3;letter-spacing:-.02em;color:var(--text);margin-bottom:16px}
    .article-meta{display:flex;align-items:center;gap:16px;font-size:12px;color:var(--text3);margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid rgba(99,102,241,.1)}
    .article-lead{font-size:15px;color:var(--text2);line-height:1.85;margin-bottom:28px;padding:18px 22px;background:rgba(99,102,241,.05);border-left:3px solid var(--indigo);border-radius:0 12px 12px 0}
    .article-body h2{font-size:20px;font-weight:900;color:var(--text);margin:36px 0 14px;padding-bottom:10px;border-bottom:2px solid rgba(99,102,241,.15);letter-spacing:-.01em}
    .article-body h3{font-size:16px;font-weight:800;color:var(--text);margin:24px 0 10px}
    .article-body p{font-size:14px;color:var(--text2);line-height:1.9;margin-bottom:16px}
    .article-body ul,.article-body ol{margin:0 0 16px 20px}
    .article-body li{font-size:14px;color:var(--text2);line-height:1.85;margin-bottom:6px}
    .article-box{border-radius:14px;padding:18px 20px;margin:20px 0}
    .article-box.info{background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.18)}
    .article-box.warn{background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2)}
    .article-box.good{background:rgba(22,163,74,.06);border:1px solid rgba(22,163,74,.18)}
    .article-box-title{font-size:12px;font-weight:800;letter-spacing:.06em;margin-bottom:10px}
    .article-box p{font-size:13px;margin-bottom:0!important}
    .article-table{width:100%;border-collapse:collapse;margin:16px 0 24px;font-size:13px}
    .article-table th{background:rgba(99,102,241,.08);color:var(--text);font-weight:700;padding:10px 14px;border:1px solid rgba(99,102,241,.12);text-align:left}
