const QS = [
  {id:"q1",q:"壁のクロスの傷・汚れで請求されていますか？",g:"通常の日焼けや画鋲穴は貸主負担が原則",t:"経年劣化・日常使用による変色・画鋲穴",l:"タバコのヤニ・ペットによる傷・大きな穴"},
  {id:"q2",q:"床（フローリング）の傷で請求されていますか？",g:"家具設置による凹みや通常使用の傷は貸主負担",t:"家具の重みによる凹み・通常の摩耗",l:"引越し作業でつけた傷・不注意による破損"},
  {id:"q3",q:"ハウスクリーニング費用を全額請求されていますか？",g:"通常清掃をしていれば貸主負担が原則（特約なし）",t:"日常的な清掃を行っていた場合",l:"著しい汚損・ゴミの放置など"},
  {id:"q4",q:"設備の故障・経年劣化で費用を請求されていますか？",g:"設備の自然劣化による故障は原則として貸主負担",t:"エアコン・給湯器などの自然故障",l:"故意・過失による破損"},
  {id:"q5",q:"入居年数は何年ですか？",type:"years",g:"居住年数が長いほど入居者の負担割合は減少します"},
];

const CHECKS=[
  {cat:"契約・書類",icon:"📋",items:["賃貸借契約書を受け取り内容を確認した","重要事項説明書を読んだ","敷金・礼金の金額を確認した","特約条項（退去時費用負担）を確認した","入居時チェックリスト（管理会社提出用）を受け取った"]},
  {cat:"設備・鍵",icon:"🔑",items:["鍵の数を確認した（主鍵・スペア）","エアコンの動作確認をした","給湯器・お湯が出ることを確認した","水回り（水漏れなし）を確認した","インターホン・ドアロックが正常に動作する"]},
  {cat:"室内状態",icon:"🏠",items:["壁・天井・床の傷・汚れを写真撮影した","窓・サッシの状態を確認した","収納・建具の開閉を確認した","照明・コンセントの動作を確認した","フローリングの傷・剥がれを記録した"]},
  {cat:"共用部・周辺",icon:"🏢",items:["ゴミ捨て場の場所・ルールを確認した","駐輪場・駐車場の位置を確認した","郵便受けの番号を確認した","宅配ボックスの使い方を確認した"]},
];

const LETTER=`■ 敷金返還請求書（内容証明用テンプレート）\n\n○○年○○月○○日\n\n貸主　○○○○　様\n\n                              借主　○○○○\n                              住所　○○○○○○\n\n          敷金返還請求書\n\n私は、貴殿との間で、下記物件について賃貸借契約を締結し、\n○○年○○月より居住してまいりましたが、○○年○○月○○日に退去いたしました。\n\nつきましては、国土交通省「原状回復をめぐるトラブルとガイドライン」に基づき、\n下記の通り敷金の返還を求めます。\n\n記\n\n1. 物件所在地：○○○○\n2. 預け入れ敷金額：金○○万円\n3. 妥当な原状回復費用：金○○万円（貴殿負担分）\n4. 返還を求める金額：金○○万円\n\n【根拠】\n・壁クロスの変色は通常の生活による経年変化であり、借主負担ではない\n  （ガイドライン：A（貸主負担）に該当）\n・床の傷は家具設置による通常損耗であり、借主負担ではない\n\n本書面到達後7日以内に、上記金額を下記口座へご返還ください。\nご対応いただけない場合は、少額訴訟その他法的手続きも検討いたします。\n\n振込先：○○銀行　○○支店　普通 ○○○○○○○\n口座名義：○○○○`;

function Chip({color,children}){
  return <span className="chip" style={{background:`${color}22`,color,border:`1px solid ${color}44`}}>{children}</span>;
}

function App(){
  const [step,setStep]=useState(0);
  const [answers,setAnswers]=useState({});
  const [years,setYears]=useState(3);
  const [result,setResult]=useState(false);
  const [clChecks,setClChecks]=useState({});
  const [openCat,setOpenCat]=useState("契約・書類");
  const [showLetter,setShowLetter]=useState(false);
  const [copied,setCopied]=useState(false);
  const [page,setPage]=useState("home"); // "home" | "blog" | article id
  const [articleId,setArticleId]=useState(null);

  // Hash routing
  useEffect(()=>{
    const onHash=()=>{
      const h=window.location.hash;
      if(h==="") {setPage("home");setArticleId(null);}
      else if(h==="#blog") {setPage("blog");setArticleId(null);window.scrollTo(0,0);}
      else if(h.startsWith("#blog/")) {
        const id=h.replace("#blog/","");
        setPage("article");setArticleId(id);window.scrollTo(0,0);
      }
      else if(h==="#privacy") {setPage("privacy");setArticleId(null);window.scrollTo(0,0);}
      else if(h==="#about") {setPage("about");setArticleId(null);window.scrollTo(0,0);}
    };
    window.addEventListener("hashchange",onHash);
    onHash();
    return ()=>window.removeEventListener("hashchange",onHash);
  },[]);

  const goHome=()=>{window.location.hash="";setPage("home");window.scrollTo(0,0)};
  const goBlog=()=>{window.location.hash="blog";};
  const goArticle=(id)=>{window.location.hash=`blog/${id}`;};
  const goPrivacy=()=>{window.location.hash="privacy";};
  const goAbout=()=>{window.location.hash="about";};
  const scroll=id=>{setPage("home");window.location.hash="";setTimeout(()=>document.getElementById(id)?.scrollIntoView({behavior:"smooth"}),50)};


  const calcScore=()=>{
    let s=0;
    if(answers.q1==="t")s+=25;
    if(answers.q2==="t")s+=20;
    if(answers.q3==="t")s+=25;
    if(answers.q4==="t")s+=15;
    s+=years>=6?15:years>=3?10:3;
    return Math.min(s,95);
  };
  const reset=()=>{setAnswers({});setStep(0);setResult(false);setYears(3)};
  const copyLetter=()=>{
    navigator.clipboard.writeText(LETTER).catch(()=>{});
    setCopied(true);setTimeout(()=>setCopied(false),2500);
  };

  const totalCl=CHECKS.reduce((a,c)=>a+c.items.length,0);
  const doneCl=Object.values(clChecks).filter(Boolean).length;
  const pctCl=Math.round(doneCl/totalCl*100);

  // DIAGNOSIS BLOCK
  let DiagContent;
  if(result){
    const sc=calcScore();
    const color=sc>=70?"#22c55e":sc>=40?"#f59e0b":"#ef4444";
    const verdict=sc>=70?"請求は不当の可能性が高い":sc>=40?"一部不当請求の可能性あり":"請求は妥当な可能性が高い";
    const emoji=sc>=70?"🚨":sc>=40?"⚠️":"✅";
    const rows=[answers.q1&&{label:"壁クロス",val:answers.q1},answers.q2&&{label:"床の傷",val:answers.q2},answers.q3&&{label:"クリーニング",val:answers.q3},answers.q4&&{label:"設備故障",val:answers.q4}].filter(Boolean);
    const acts=[sc>=70&&"内容証明を送付して敷金返還を正式に請求する",sc>=50&&"見積書の内訳・根拠を書面で求める","国民生活センター（188番）に相談する","少額訴訟（60万円以下・1回審理）を検討する"].filter(Boolean);
    DiagContent=(
      <div className="diag-card">
        <div className="score-box">
          <div style={{fontSize:52,marginBottom:8}}>{emoji}</div>
          <div className="score-num" style={{color}}>{sc}<span className="score-unit">点</span></div>
          <div className="score-label" style={{color}}>{verdict}</div>
          <div style={{fontSize:11,color:"var(--text3)",marginTop:6}}>居住年数：{years}年</div>
        </div>
        <div style={{background:`${color}0d`,border:`1px solid ${color}44`,borderRadius:14,padding:"14px 16px",marginBottom:14}}>
          <div style={{fontSize:11,fontWeight:700,color,marginBottom:10}}>判定サマリー</div>
          {rows.map((r,i)=>(
            <div key={i} className="result-row">
              <span style={{fontSize:13,color:"var(--text2)"}}>{r.label}</span>
              <Chip color={r.val==="t"?"#22c55e":r.val==="l"?"#ef4444":"#6b7280"}>{r.val==="t"?"貸主負担の可能性":r.val==="l"?"借主負担":"不明"}</Chip>
            </div>
          ))}
        </div>
        <div style={{background:"rgba(99,102,241,.04)",border:"1px solid rgba(99,102,241,.1)",borderRadius:14,padding:"14px 16px",marginBottom:16}}>
          <div style={{fontSize:11,fontWeight:700,color:"#f59e0b",marginBottom:10}}>今すぐやること</div>
          {acts.map((a,i)=>(
            <div key={i} className="action-item">
              <div className="action-num">{i+1}</div>
              <div style={{fontSize:13,color:"var(--text2)",lineHeight:1.6}}>{a}</div>
            </div>
          ))}
        </div>
        <div style={{display:"flex",gap:10}}>
          <button className="diag-btn" style={{background:"linear-gradient(135deg,#10b981,#34d399)"}} onClick={()=>scroll("documents")}>書類を作成する →</button>
          <button onClick={reset} style={{flexShrink:0,padding:"14px 16px",borderRadius:13,border:"1px solid rgba(99,102,241,.2)",background:"#f0f4ff",color:"var(--indigo)",fontSize:13,fontWeight:600,cursor:"pointer"}}>再診断</button>
        </div>
      </div>
    );
  } else {
    const q=QS[step];
    DiagContent=(
      <div className="diag-card">
        <div className="step-bar">{QS.map((_,i)=><div key={i} className={`step-seg ${i<step?"done":i===step?"cur":"todo"}`}/>)}</div>
        <div style={{fontSize:11,color:"var(--text3)",marginBottom:16}}>{step+1} / {QS.length}</div>
        <div className="q-text">{q.q}</div>
        <div className="q-hint">💡 {q.g}</div>
        {q.type==="years"?(
          <>
            <div style={{fontSize:13,fontWeight:700,color:"var(--text2)",marginBottom:12}}>居住年数を選択</div>
            <div className="year-grid">
              {[1,2,3,4,5,6,8,10,12].map(y=>(
                <button key={y} className={`year-btn${years===y?" on":""}`} onClick={()=>setYears(y)}>{y}年</button>
              ))}
            </div>
            <button className="diag-btn" onClick={()=>{if(step+1<QS.length)setStep(s=>s+1);else setResult(true);}}>診断結果を見る →</button>
          </>
        ):[
          {val:"t",emoji:"✅",label:q.t,cls:"sel-t"},
          {val:"l",emoji:"❌",label:q.l,cls:"sel-l"},
          {val:"s",emoji:"◻",label:"該当しない / わからない",cls:"sel-s"},
        ].map(opt=>(
          <button key={opt.val} className={`choice-btn${answers[q.id]===opt.val?" "+opt.cls:""}`}
            onClick={()=>{setAnswers(p=>({...p,[q.id]:opt.val}));setTimeout(()=>{if(step+1<QS.length)setStep(s=>s+1);else setResult(true);},200);}}>
            <div className="choice-inner"><span className="choice-emoji">{opt.emoji}</span><span className="choice-label">{opt.label}</span></div>
          </button>
        ))}
      </div>
    );
  }

  return (
    <>
      <div className="glow"/>

      {/* NAV */}
      <nav className="site-nav">
        <button className="nav-logo" onClick={goHome}>
          <img src="data:image/png;base64," style={{width:"36px",height:"36px",objectFit:"contain"}} alt="タチアイズ" />
          タチアイズ
        </button>
        <div className="nav-links">
          {page==="home"
            ? [["退去費用診断","diagnosis"],["入居前チェック","checklist"],["交渉書類","documents"]].map(([l,id])=>(
                <button key={id} className="nav-link" onClick={()=>scroll(id)}>{l}</button>
              ))
            : <button className="nav-link" onClick={goHome}>ホームへ戻る</button>
          }
          <button className="nav-link" onClick={goBlog} style={{color:page==="blog"||page==="article"?"var(--indigo)":""}}>ブログ</button>
          <button className="nav-link" onClick={goAbout} style={{color:page==="about"?"var(--indigo)":""}}>運営者情報</button>
        </div>
        <button className="nav-cta" onClick={()=>{goHome();setTimeout(()=>document.getElementById("diagnosis")?.scrollIntoView({behavior:"smooth"}),100)}}>無料で診断する</button>
      </nav>

      {/* ── HOME ── */}
      {page==="home" && <div style={{position:"relative",zIndex:1}}>
        <div className="hero">
          <div className="hero-inner">
            <div className="fu">
              <div className="hero-badge">🛡️ 国土交通省ガイドライン準拠</div>
              <h1 className="hero-h1">その退去費用、<br/><em>払いすぎ</em>ていませんか？</h1>
              <p className="hero-sub">請求書の金額と国交省ガイドラインを比較して、<strong style={{color:"var(--text)"}}>不当な請求額をAIが無料で診断</strong>します。入居者の73%に不当な請求が含まれています。</p>
              <div className="hero-btns">
                <button className="btn-primary" onClick={()=>scroll("diagnosis")}>無料で差額を確認する →</button>
                <button className="btn-ghost" onClick={()=>scroll("checklist")}>入居前チェックリスト</button>
              </div>
              <div className="trust-row">
                {["完全無料","2分で完了","クレジットカード不要"].map(t=>(
                  <div key={t} className="trust-item">
                    <div className="trust-check">✓</div>{t}
                  </div>
                ))}
              </div>
            </div>
            <div className="fu2">
              <div className="hero-card">
                <div className="card-label"><span style={{width:8,height:8,borderRadius:"50%",background:"#22c55e",display:"inline-block"}}/> 診断結果レポート（サンプル）</div>
                <div className="diff-block">
                  <div className="diff-label">ガイドライン参考計算値との差額</div>
                  <div className="diff-amount">-¥67,000</div>
                  <div className="diff-sub">このぶん返還できる可能性があります</div>
                </div>
                {[{label:"請求額",val:"¥185,000",c:"#dc2626"},{label:"参考額",val:"¥118,000",c:"#818cf8"}].map(r=>(
                  <div key={r.label} className="card-row"><span style={{fontSize:12,color:"var(--text2)"}}>{r.label}</span><span style={{fontSize:12,fontWeight:700,color:r.c}}>{r.val}</span></div>
                ))}
                <div style={{marginTop:12,fontSize:11,color:"var(--text3)",fontWeight:700,marginBottom:6}}>項目別内訳（算出根拠付き）</div>
                {[["壁紙","-¥25,000","耐用年数6年超過"],["クリーニング","-¥35,000","特約に金額未明記"],["鍵交換","-¥15,000","貸主負担と明記"]].map(([n,a,r],i)=>(
                  <div key={i} className="card-row">
                    <div style={{fontSize:12}}><span style={{marginRight:7,fontSize:9,background:"rgba(99,102,241,.2)",color:"var(--indigo)",padding:"2px 5px",borderRadius:4,fontWeight:700}}>{i+1}</span>{n}</div>
                    <div style={{textAlign:"right"}}><div style={{fontSize:12,fontWeight:700,color:"#34d399"}}>{a}</div><div style={{fontSize:10,color:"var(--text3)"}}>{r}</div></div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        {/* STATS */}
        <div className="stats-bar">
          <div className="stats-inner">
            {[["¥92,000","ユーザー平均の差額"],["73%","不当請求を含む割合"],["2分","診断にかかる時間"]].map(([n,l])=>(
              <div key={l} className="stat-cell"><div className="stat-num">{n}</div><div className="stat-label">{l}</div></div>
            ))}
          </div>
        </div>

        {/* PAIN POINTS */}
        <section>
          <div className="wrap">
            <div className="sec-badge">こんなお悩みありませんか？</div>
            <h2 className="sec-h2">退去費用トラブルは<br/>解決できます</h2>
            <div className="pain-grid">
              {[
                {icon:"😰",title:"請求額が高すぎる気がする",text:"管理会社から届いた請求書を見て「払いすぎでは？」と感じている",sol:"→ AIが差額を自動計算"},
                {icon:"😕",title:"何が自分の負担かわからない",text:"どの項目が借主負担でどれが貸主負担なのか判断できない",sol:"→ 国交省基準で自動判定"},
                {icon:"😤",title:"管理会社と揉めたくない",text:"証拠や根拠がないと交渉できないので言われた通り払うしかない",sol:"→ 根拠付きレポートを生成"},
                {icon:"😖",title:"専門家に相談するお金がない",text:"弁護士や行政書士に相談すると費用が数万円かかる",sol:"→ 完全無料で使えます"},
              ].map(p=>(
                <div key={p.title} className="pain-card">
                  <div className="pain-icon">{p.icon}</div>
                  <div className="pain-title">{p.title}</div>
                  <div className="pain-text">{p.text}</div>
                  <span className="pain-sol">{p.sol}</span>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* HOW */}
        <section style={{background:"#eef1fb"}}>
          <div className="wrap">
            <div className="sec-badge">使い方</div>
            <h2 className="sec-h2">3ステップで解決</h2>
            <div className="how-grid">
              {[
                {n:"STEP 01",icon:"📝",title:"基本情報を入力",text:"間取り・居住年数・請求金額を入力するだけ。請求書がなくても概算金額でOK。"},
                {n:"STEP 02",icon:"⚖️",title:"AIが診断",text:"国交省ガイドラインに基づいて各項目の妥当性を自動判定し、差額を算出。"},
                {n:"STEP 03",icon:"📄",title:"書類をコピーして交渉",text:"管理会社に送れる確認文テンプレートを即座に生成。コピーして送るだけ。"},
              ].map(h=>(
                <div key={h.n} className="how-card">
                  <div className="how-num">{h.n}</div>
                  <div className="how-icon">{h.icon}</div>
                  <div className="how-title">{h.title}</div>
                  <div className="how-text">{h.text}</div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* DIAGNOSIS */}
        <section id="diagnosis">
          <div className="wrap">
            <div className="sec-badge">退去費用診断</div>
            <h2 className="sec-h2">あなたの差額を今すぐ確認する</h2>
            <p className="sec-sub">5問に答えるだけで、国交省ガイドラインに基づいた判定結果をすぐに確認できます。</p>
            <div className="diag-wrap">{DiagContent}</div>
          </div>
        </section>

        {/* CHECKLIST */}
        <section id="checklist" style={{background:"var(--bg2)"}}>
          <div className="wrap">
            <div className="sec-badge">入居前チェックリスト</div>
            <h2 className="sec-h2">入居時の記録が最大の防衛策</h2>
            <p className="sec-sub">退去時のトラブルを防ぐには入居時の状態記録が最重要。入居直後に以下をチェックしてください。</p>
            <div style={{maxWidth:480,margin:"20px 0",background:"rgba(99,102,241,.04)",border:"1px solid rgba(99,102,241,.1)",borderRadius:14,padding:"16px 20px"}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                <span style={{fontSize:13,color:"var(--text2)"}}>完了 {doneCl} / {totalCl} 項目</span>
                <span style={{fontSize:13,fontWeight:700,color:"#34d399"}}>{pctCl}%</span>
              </div>
              <div style={{height:6,borderRadius:999,background:"rgba(99,102,241,.1)",overflow:"hidden"}}>
                <div style={{height:"100%",borderRadius:999,width:`${pctCl}%`,background:"linear-gradient(90deg,#22c55e,#34d399)",transition:"width .4s ease"}}/>
              </div>
            </div>
            <div className="cl-grid">
              {CHECKS.map(cat=>{
                const catDone=cat.items.filter((_,i)=>clChecks[`${cat.cat}-${i}`]).length;
                const allDone=catDone===cat.items.length;
                const isOpen=openCat===cat.cat;
                const pct=Math.round(catDone/cat.items.length*100);
                return (
                  <div key={cat.cat} className="cl-cat" style={{borderColor:allDone?"rgba(22,163,74,.3)":"rgba(99,102,241,.12)"}}>
                    <div className="cl-prog-bar"><div className="cl-prog-fill" style={{width:`${pct}%`}}/></div>
                    <div className="cl-cat-hd" onClick={()=>setOpenCat(isOpen?null:cat.cat)}>
                      <div className="cl-cat-left">
                        <span style={{fontSize:22}}>{cat.icon}</span>
                        <div>
                          <div style={{fontSize:14,fontWeight:700,color:allDone?"#16a34a":"var(--text)"}}>{cat.cat}</div>
                          <div style={{fontSize:11,color:"var(--text3)",marginTop:1}}>{catDone}/{cat.items.length}完了</div>
                        </div>
                      </div>
                      <span style={{color:"var(--text3)",fontSize:18,transition:"transform .2s",display:"inline-block",transform:isOpen?"rotate(90deg)":"none"}}>›</span>
                    </div>
                    {isOpen&&(
                      <div className="cl-items">
                        {cat.items.map((item,i)=>{
                          const key=`${cat.cat}-${i}`;const done=!!clChecks[key];
                          return (
                            <div key={i} className="cl-item" onClick={()=>setClChecks(p=>({...p,[key]:!p[key]}))}>
                              <div className={`cl-check${done?" on":""}`}>{done?"✓":""}</div>
                              <span style={{fontSize:13,color:done?"var(--text3)":"var(--text)",textDecoration:done?"line-through":"none",lineHeight:1.5,transition:"color .2s"}}>{item}</span>
                            </div>
                          );
                        })}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
            <div className="gl-table">
              <div className="gl-title">国交省ガイドライン早見表</div>
              {[["通常損耗・経年劣化","貸主負担","#22c55e"],["故意・過失による損傷","借主負担","#ef4444"],["タバコのヤニ汚れ","借主負担","#ef4444"],["画鋲・ピンの穴（小）","貸主負担","#22c55e"]].map(([item,who,c])=>(
                <div key={item} className="gl-row">
                  <span style={{fontSize:13,color:"var(--text2)"}}>{item}</span>
                  <Chip color={c}>{who}</Chip>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* DOCUMENTS */}
        <section id="documents">
          <div className="wrap">
            <div className="sec-badge">交渉書類</div>
            <h2 className="sec-h2">すぐ使える交渉テンプレート</h2>
            <p className="sec-sub">管理会社への確認文・内容証明・異議申し立て書類をワンクリックで生成します。</p>
            <div className="doc-grid">
              {[
                {icon:"✉️",bg:"rgba(34,197,94,.12)",title:"敷金返還請求書（内容証明）",desc:"最も効果的。法的効力のある書面で敷金返還を正式に請求できます。",chip:{c:"#22c55e",l:"最推奨"},action:()=>setShowLetter(true)},
                {icon:"🚫",bg:"rgba(99,102,241,.12)",title:"不当請求への異議申し立て",desc:"見積もりの根拠開示を求める正式な書面。管理会社に証拠提出を求めます。",chip:{c:"#6366f1",l:"効果的"},action:()=>alert("フルバージョンで利用できます")},
                {icon:"⚖️",bg:"rgba(245,158,11,.12)",title:"少額訴訟申立書サポート",desc:"60万円以下・1回の審判で解決できる少額訴訟の申立書類を作成。",chip:{c:"#f59e0b",l:"最終手段"},action:()=>alert("フルバージョンで利用できます")},
                {icon:"📊",bg:"rgba(167,139,250,.12)",title:"原状回復費用計算シート",desc:"居住年数・面積から適正な原状回復費用を自動算出するシートを生成。",chip:{c:"#a78bfa",l:"便利"},action:()=>alert("フルバージョンで利用できます")},
              ].map(doc=>(
                <div key={doc.title} className="doc-card" onClick={doc.action}>
                  <div className="doc-icon" style={{background:doc.bg}}>{doc.icon}</div>
                  <div>
                    <div style={{display:"flex",alignItems:"center",gap:8,flexWrap:"wrap",marginBottom:5}}>
                      <div className="doc-title">{doc.title}</div>
                      <Chip color={doc.chip.c}>{doc.chip.l}</Chip>
                    </div>
                    <div className="doc-desc">{doc.desc}</div>
                  </div>
                </div>
              ))}
            </div>
            <div style={{background:"rgba(99,102,241,.05)",border:"1px solid rgba(99,102,241,.15)",borderRadius:16,padding:20,marginTop:20}}>
              <div style={{fontSize:12,fontWeight:700,color:"var(--indigo)",marginBottom:10}}>交渉の鉄則</div>
              {["すべての連絡は書面（LINE・メールでも可）で記録を残す","口頭での合意は証拠にならない。必ず書面化する","感情的にならず、法律・ガイドラインの条文を引用する","7日以内の返答期限を設け、無視されたら次の行動へ"].map((tip,i,arr)=>(
                <div key={i} style={{display:"flex",gap:10,alignItems:"flex-start",padding:"9px 0",borderBottom:i<arr.length-1?"1px solid rgba(99,102,241,.08)":"none"}}>
                  <span style={{width:20,height:20,borderRadius:6,background:"rgba(99,102,241,.1)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:10,fontWeight:700,color:"var(--indigo)",flexShrink:0}}>{i+1}</span>
                  <span style={{fontSize:12,color:"var(--text2)",lineHeight:1.7}}>{tip}</span>
                </div>
              ))}
            </div>
          </div>
        </section>

