              <p className="sec-sub">国土交通省ガイドラインをもとに、退去費用・敷金トラブルに関する正確な情報をお届けします。</p>
            </div>
          </div>
          <section style={{background:"var(--bg)"}}>
            <div className="wrap">
              <div className="blog-grid">
                {ARTICLES.map(a=>(
                  <div key={a.id} className="blog-card" onClick={()=>goArticle(a.id)}>
                    <div className="blog-card-img" style={{background:a.bg}}>{a.icon}</div>
                    <div className="blog-card-body">
                      <span className="blog-tag" style={{background:`${a.tagColor}18`,color:a.tagColor,border:`1px solid ${a.tagColor}30`}}>{a.tag}</span>
                      <div className="blog-card-title">{a.title}</div>
                      <div className="blog-card-excerpt">{a.excerpt}</div>
                      <div className="blog-card-meta">
                        <span>{a.date}</span>
                        <span>・</span>
                        <span>読了{a.readMin}分</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
          <footer>
            <div className="footer-inner">
              <div>
                <div style={{fontSize:15,fontWeight:900,color:"var(--text)"}}>🛡️ タチアイズ</div>
                <div style={{fontSize:11,color:"var(--text3)",marginTop:6}}>© 2026 タチアイズ</div>
                <div style={{display:"flex",gap:14,marginTop:10}}>
                  <button onClick={goAbout} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:"var(--indigo)",padding:0}}>運営者情報</button>
                  <button onClick={goPrivacy} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:"var(--indigo)",padding:0}}>プライバシーポリシー</button>
                </div>
              </div>
              <div className="footer-note">本サービスは法律相談・交渉代行ではありません。国土交通省「原状回復をめぐるトラブルとガイドライン」に基づく一般的な参考情報の提供です。</div>
            </div>
          </footer>
        </div>
      )}

      {/* ── ARTICLE PAGE ── */}
      {page==="article" && (()=>{
        const a = ARTICLES.find(x=>x.id===articleId);
        if(!a) return <div style={{padding:"100px 24px",textAlign:"center",color:"var(--text2)"}}>記事が見つかりません</div>;
        const others = ARTICLES.filter(x=>x.id!==a.id);
        return (
          <div style={{position:"relative",zIndex:1}}>
            <div className="article-wrap">
              <div className="article-inner">
                {/* Breadcrumb */}
                <div className="breadcrumb">
                  <button onClick={goHome}>ホーム</button>
                  <span>›</span>
                  <button onClick={goBlog}>ブログ</button>
                  <span>›</span>
                  <span style={{color:"var(--text3)"}}>{a.tag}</span>
                </div>

                <span className="article-tag" style={{background:`${a.tagColor}18`,color:a.tagColor,border:`1px solid ${a.tagColor}30`}}>{a.tag}</span>
                <h1 className="article-h1">{a.title}</h1>
                <div className="article-meta">
                  <span>📅 {a.date}</span>
                  <span>🕐 読了 {a.readMin}分</span>
                  <span style={{marginLeft:"auto",background:a.bg,borderRadius:8,padding:"3px 10px",fontSize:11,fontWeight:700}}>SEOキーワード：{a.keyword}</span>
                </div>

                <p className="article-lead">{a.excerpt}</p>

                <div className="article-body" dangerouslySetInnerHTML={{__html:a.body}}/>

                {/* CTA in article */}
                <div className="article-cta">
                  <div style={{fontSize:36,marginBottom:10}}>🛡️</div>
                  <h3>退去費用の不当請求、無料で診断します</h3>
                  <p>2分の診断で、あなたの退去費用が適正かどうかを国交省ガイドラインに基づき判定します。</p>
                  <button className="btn-primary" onClick={()=>{goHome();setTimeout(()=>document.getElementById("diagnosis")?.scrollIntoView({behavior:"smooth"}),100)}}>
                    無料で診断する →
